{
  "result": {
    "input_variables": [
      {
        "name": "role_name",
        "description": "角色名称",
        "type": "string",
        "constraints": "长度2-12字符，允许中文、英文、数字，不允许特殊字符和空格，不能与已有角色重复"
      },
      {
        "name": "strength",
        "description": "力量属性",
        "type": "numeric",
        "constraints": "1-10点整数，分配后四项属性总和必须等于20"
      },
      {
        "name": "agility",
        "description": "敏捷属性",
        "type": "numeric",
        "constraints": "1-10点整数，分配后四项属性总和必须等于20"
      },
      {
        "name": "intelligence",
        "description": "智力属性",
        "type": "numeric",
        "constraints": "1-10点整数，分配后四项属性总和必须等于20"
      },
      {
        "name": "constitution",
        "description": "体质属性",
        "type": "numeric",
        "constraints": "1-10点整数，分配后四项属性总和必须等于20"
      },
      {
        "name": "profession",
        "description": "职业选择",
        "type": "enum",
        "constraints": "战士、法师、盗贼、牧师，需满足相应属性要求"
      },
      {
        "name": "level",
        "description": "角色等级",
        "type": "numeric",
        "constraints": "1-100整数，初始为1，每升一级获得5点属性点"
      }
    ],
